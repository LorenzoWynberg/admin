# =============================================================================
# Mandados — ADMIN dashboard environment (Next.js)
# =============================================================================
# Copy to `.env.local` for local dev:  cp .env.example .env.local
#
# All vars are NEXT_PUBLIC_* — they are inlined into the browser bundle at BUILD
# time, so they are publicly visible. Only put browser-safe values here, and
# redeploy after changing any of them.
# =============================================================================

# REQUIRED. Base URL of the Laravel API.
#   Local:      http://api.mandados.test:60
#   Production:  https://api.mandados.com
NEXT_PUBLIC_API_URL=http://api.mandados.test:60

# Google Maps JS API key used by the admin map views.
# Restrict it by HTTP referrer (your admin domain) in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Laravel Reverb (WebSocket / real-time) ----------------------------------
# Live updates via Laravel Echo + Reverb. These MUST match the REVERB_* values
# configured on the API (the Reverb server) and the client/driver apps.
#   Local:      HOST=localhost      PORT=8080  SCHEME=http
#   Production:  HOST=ws.mandados.cr  PORT=443   SCHEME=https
# NEXT_PUBLIC_REVERB_APP_KEY is a public client key (safe to expose).
NEXT_PUBLIC_REVERB_APP_KEY=
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http

# --- Firebase Cloud Messaging (web push) -------------------------------------
# FCM web push, matching the client and driver apps. Same Firebase project
# (mandados-3dc63); all values below are PUBLIC (the Web SDK config is not a
# secret) and are also hard-coded in public/firebase-messaging-sw.js.
# NEXT_PUBLIC_FIREBASE_VAPID_KEY is the project's Web Push certificate key.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
